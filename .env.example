# ============================================================
# Quantum Risk Analytics — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env — apenas o .env.example vai ao repo.
# ============================================================

# --- Parâmetros de risco ---
RISK_FREE_RATE=0.1175
CONFIDENCE_LEVEL=0.95
DEFAULT_INVESTMENT=100000

# --- Email (Gmail recomendado com App Password) ---
# Para Gmail: Conta > Segurança > Verificação em duas etapas > Senhas de app
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx   # App Password de 16 chars, não sua senha real
EMAIL_TO=destinatario@email.com      # Pode ser o mesmo EMAIL_USER

# --- Telegram (opcional) ---
# 1. Crie um bot: fale com @BotFather no Telegram
# 2. Obtenha TELEGRAM_TOKEN do BotFather
# 3. Obtenha TELEGRAM_CHAT_ID: envie mensagem ao bot, acesse
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# --- Ativos padrão para ETL agendado ---
DEFAULT_TICKERS=PETR4.SA,VALE3.SA,ITUB4.SA,BBDC4.SA,WEGE3.SA

# --- Alertas ---
VAR_ALERT_THRESHOLD=0.05    # Alerta se VaR diário > 5%
DRAWDOWN_ALERT_THRESHOLD=0.15  # Alerta se drawdown > 15%
